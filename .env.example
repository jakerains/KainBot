# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Shared secret for Eve agent ↔ Nuxt internal API (memory, Slack link).
# Must match on both the Nuxt app and the Eve service in production.
INTERNAL_API_SECRET=change-me-to-a-random-string-at-least-32-chars

# Database — Neon Postgres. Auto-provisioned by the Vercel Neon integration and written to
# .env.local locally. Must be present on BOTH the web and eve services in production
# (the eve service validates web sessions via Better Auth in-process).
#   DATABASE_URL          pooled (PgBouncer) connection — runtime (server/db/client.ts)
#   DATABASE_URL_UNPOOLED direct connection — drizzle-kit migrations (drizzle.config.ts)
# DATABASE_URL=postgres://...
# DATABASE_URL_UNPOOLED=postgres://...

# Sendblue (iMessage) — set on the eve service. Numbers in E.164 (e.g. +15551234567).
# SENDBLUE_API_KEY=
# SENDBLUE_API_SECRET=
# SENDBLUE_FROM_NUMBER=
# SENDBLUE_WEBHOOK_SECRET=

# Optional — canonical URL for SEO (Open Graph, canonical links)
# NUXT_PUBLIC_SITE_URL=https://your-app.vercel.app
